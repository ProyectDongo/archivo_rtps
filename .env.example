# ─── Configuración Django ────────────────────────────────────
# Genera una nueva con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambiame-en-produccion

# False en producción
DEBUG=False

# Lista separada por comas. Ejemplo producción:
#   ALLOWED_HOSTS=archivo.pietramonte.cl
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Acceso al portal ────────────────────────────────────────
# La allowlist del portal es la tabla UsuarioPortal en BD (admin de Django).
# Crea ahí los emails que pueden entrar y asígnales password + buzones visibles.

# Email del administrador (notificaciones operacionales).
PORTAL_ADMIN_EMAIL=soporte.dongo@gmail.com

# ─── Admin web (Django) ──────────────────────────────────────
# Ruta donde vive el panel de administración. Cambiala por algo
# difícil de adivinar. En producción ponla detrás de Cloudflare Access.
ADMIN_URL_PATH=admin-pm-staff

# ─── Email / SMTP ────────────────────────────────────────────
# En desarrollo dejá el backend de consola: imprime los emails en stdout
# en vez de mandar nada real.
# En producción setear EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=soporte.dongo@gmail.com
# EMAIL_HOST_PASSWORD=  # 16 chars sin espacios del App Password de Gmail (Is Secret)
# DEFAULT_FROM_EMAIL=Pietramonte <noreply@pietramonte.cl>

# Aliases por tipo (deben estar configurados como "Send mail as" en la cuenta Gmail).
# Si no se setean, todos caen a DEFAULT_FROM_EMAIL.
# EMAIL_AGENDA_FROM=Agenda Pietramonte <agenda@pietramonte.cl>
# EMAIL_COTIZACIONES_FROM=Cotizaciones Pietramonte <cotizaciones@pietramonte.cl>
# EMAIL_REENVIO_FROM=Pietramonte Equipo <soporte.dongo@gmail.com>
# EMAIL_REPLY_TO_AGENDA=agenda@pietramonte.cl
# EMAIL_REPLY_TO_COTIZACIONES=cotizaciones@pietramonte.cl

# Listas de admins (CSV) que reciben notificaciones operacionales.
# ADMIN_NOTIFY_AGENDA=jefe@correo.cl,recepcionista@correo.cl,soporte.dongo@gmail.com
# ADMIN_NOTIFY_COTIZACIONES=jefe@correo.cl,vendedor@correo.cl,soporte.dongo@gmail.com

# ─── Anti-bot del form público de reservas ───────────────────
# Cloudflare Turnstile (gratis, invisible). Sacá las keys en
# https://dash.cloudflare.com/ → Turnstile → Add Site.
# En dev podés dejarlas vacías → la verificación se bypass-ea.
# TURNSTILE_SITE_KEY=0x4AAAAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...   # Is Secret en Coolify

# Dominios extras a bloquear como desechables (CSV).
# DISPOSABLE_DOMAINS_EXTRA=ejemplo-spam.com,otro-temp.io

# ─── Sincronización Gmail (Fase 5) ───────────────────────────
# GMAIL_OAUTH_CLIENT_ID=
# GMAIL_OAUTH_CLIENT_SECRET=
# GMAIL_OAUTH_REFRESH_TOKEN=
# GMAIL_ARCHIVE_ACCOUNT=soporte.dongo@gmail.com

# ─── Cache backend (Redis) ───────────────────────────────────
# Si querés que el rate-limit y los throttles funcionen consistentes entre
# múltiples gunicorn workers, configurá Redis (Coolify lo ofrece como service).
# Sin esto, el cache cae a LocMemCache (per-worker — degradación graceful).
# REDIS_URL=redis://redis:6379/0

# ─── Proxies confiables (X-Forwarded-For) ────────────────────
# CSV de IPs / CIDRs de los proxies que pueden setear XFF. Si la conexión
# llega de un IP que NO está en esta lista, ignoramos XFF y usamos REMOTE_ADDR
# (sino un atacante podría spoofear IP burlando rate-limit).
# En Coolify+Cloudflare Tunnel, el remote_addr suele ser la red docker interna.
# TRUSTED_PROXIES=172.17.0.0/16,10.0.0.0/8

# ─── Logging ─────────────────────────────────────────────────
# Nivel para loggers de apps propias. DEBUG / INFO / WARNING / ERROR.
# LOG_LEVEL=INFO
# LOG_SQL=0   # Solo con DEBUG=1: loguea cada query SQL — caro.
