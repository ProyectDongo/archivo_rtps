# ════════════════════════════════════════════════════════════════════
#   .env de PRODUCCIÓN — copialo a .env en el servidor y rellena.
#
#   NUNCA subas este archivo con valores reales a git.
#   El .gitignore ya excluye .env (no .env.production.example).
# ════════════════════════════════════════════════════════════════════

# ─── Django ─────────────────────────────────────────────────────────
# Generala con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=GENERA-UNA-CLAVE-LARGA-Y-ALEATORIA

DEBUG=False

# Dominio público (separado por comas)
ALLOWED_HOSTS=archivo.pietramonte.cl


# ─── Admin de Django ─────────────────────────────────────────────────
# URL ofuscada del panel admin. Cambia el sufijo por algo ÚNICO.
# En prod, además ponlo detrás de Cloudflare Access.
ADMIN_URL_PATH=admin-pm-CAMBIA-ESTO-POR-ALGO-RANDOM


# ─── Acceso al portal ────────────────────────────────────────────────
# La allowlist real es la tabla UsuarioPortal en BD: cada email creado ahí
# (con password + buzones visibles + 2FA) puede entrar.
#
# Email destinatario para notificaciones operacionales (alertas, agendamientos).
PORTAL_ADMIN_EMAIL=soporte.dongo@gmail.com


# ─── Email / SMTP (PRODUCCIÓN) ──────────────────────────────────────
# Cuenta Gmail real para autenticar SMTP. Las direcciones "From" pueden ser
# alias de pietramonte.cl (vía Cloudflare Email Routing + Gmail "Send mail as").
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=soporte.dongo@gmail.com
EMAIL_HOST_PASSWORD=                    # 16 chars sin espacios del App Password (¡Is Secret!)

DEFAULT_FROM_EMAIL=Pietramonte <noreply@pietramonte.cl>

# Aliases por tipo de notificación (configurar como "Send mail as" en Gmail antes).
EMAIL_AGENDA_FROM=Agenda Pietramonte <agenda@pietramonte.cl>
EMAIL_COTIZACIONES_FROM=Cotizaciones Pietramonte <cotizaciones@pietramonte.cl>
EMAIL_REENVIO_FROM=Equipo Pietramonte <soporte.dongo@gmail.com>
EMAIL_REPLY_TO_AGENDA=agenda@pietramonte.cl
EMAIL_REPLY_TO_COTIZACIONES=cotizaciones@pietramonte.cl

# Lista de admins a notificar (CSV). Se mandan los avisos operacionales acá.
ADMIN_NOTIFY_AGENDA=soporte.dongo@gmail.com
ADMIN_NOTIFY_COTIZACIONES=soporte.dongo@gmail.com


# ─── Anti-bot del form público de reservas (PRODUCCIÓN) ─────────────
# Cloudflare Turnstile — obligatorio en prod.
# https://dash.cloudflare.com/ → Turnstile → Add Site → Hostname: archivo.pietramonte.cl
# Widget mode: "Managed" (default), Captcha mode: "Non-interactive".
TURNSTILE_SITE_KEY=                     # Site key (público — va al HTML)
TURNSTILE_SECRET_KEY=                   # Secret key (Is Secret en Coolify)

# Dominios extras a bloquear como desechables (CSV). Se SUMAN a los ~150 que vienen bundlados.
# DISPOSABLE_DOMAINS_EXTRA=


# ─── Sincronización Gmail (Fase futura — déjalo comentado por ahora) ──
# GMAIL_OAUTH_CLIENT_ID=
# GMAIL_OAUTH_CLIENT_SECRET=
# GMAIL_OAUTH_REFRESH_TOKEN=
# GMAIL_ARCHIVE_ACCOUNT=soporte.dongo@gmail.com
